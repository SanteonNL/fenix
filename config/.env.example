# Secrets Configuration for fenix
# Copy this file to .env and fill in the actual secret values

# Database connection for HIX SQL Server
HIX_USER=sa
HIX_PASSWORD=your_password_here

# ZBJ-test SFTP (Azure Blob Storage SFTP)
ZBJ_SFTP_HOST=zbjtest.blob.core.windows.net
ZBJ_SFTP_USER=zbjtest.zbj-test.sftpuser
