# Environment Configuration Example
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit the actual .env file to version control

# LUSCII API Configuration
LUSCII_API_KEY=your_luscii_api_key_here
LUSCII_BASE_URL=https://vitalsapi.luscii.com

# HIX SQL Server Configuration
HIX_CONNECTION_STRING=server=localhost;user id=sa;password=YourStrongPassword123!;port=1433;database=hix_test

# Data Lake Configuration (optional)
DATALAKE_URL=dls-t.hips.santeon.nl
DATALAKE_CLIENT_ID=your_client_id_here
DATALAKE_CERTIFICATE_PATH=/path/to/certificate.pem
DATALAKE_CERTIFICATE_KEY_PATH=/path/to/certificate-key.pem

# Staging Database Configuration (optional, if using PostgreSQL)
STAGING_CONNECTION_STRING=host=localhost user=fenix dbname=staging password=your_password_here
