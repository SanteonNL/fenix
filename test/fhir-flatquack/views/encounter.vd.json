{
  "resourceType": "ViewDefinition",
  "name": "encounter_flat",
  "resource": "Encounter",
  "description": "Flattened view of Encounters — one row per encounter, code systems as separate columns",
  "select": [
    {
      "column": [
        { "name": "id", "path": "id", "type": "id" },
        { "name": "patient_ref", "path": "subject.reference", "type": "string" },
        { "name": "status", "path": "status", "type": "code" },
        { "name": "encounter_type", "path": "type.text", "type": "string" },
        { "name": "service_provider", "path": "serviceProvider.display", "type": "string" }
      ]
    },
    {
      "forEach": "type.coding.where(system = 'http://snomed.info/sct')",
      "column": [
        { "name": "snomed_code",    "path": "code",    "type": "code" },
        { "name": "snomed_display", "path": "display", "type": "string" }
      ]
    },
    {
      "forEach": "type.coding.where(system = 'http://terminology.hl7.org/CodeSystem/v3-ActCode')",
      "column": [
        { "name": "act_code",    "path": "code",    "type": "code" },
        { "name": "act_display", "path": "display", "type": "string" }
      ]
    }
  ]
}
